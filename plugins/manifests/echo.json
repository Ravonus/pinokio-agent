{
  "api_version": "pinokio.plugin/v1",
  "id": "pinokio.echo",
  "name": "Echo",
  "version": "1.0.0",
  "description": "Simple echo plugin used for smoke tests and dry-run orchestration.",
  "runtime": {
    "mode": "container",
    "requires_container": false,
    "unsafe_host_access": false
  },
  "extends": {
    "agents": ["echo"],
    "containers": [],
    "navigation": [],
    "settings": ["echo"],
    "pages": [],
    "resources": ["plugin:echo"],
    "hooks": []
  },
  "plugins": [
    {
      "name": "echo",
      "command": "node plugins/echo-plugin.ts",
      "host_only": false,
      "allowed_actions": ["read", "create", "update", "delete"],
      "managed_only": false,
      "dependencies": [],
      "capabilities": {
        "allow_spawn_child": false,
        "allow_hook_requests": false,
        "allow_network": false,
        "allow_filesystem": false
      },
      "permissions": {
        "create": true,
        "read": true,
        "update": true,
        "delete": true,
        "spawn_child": false,
        "hook_extensions": false,
        "network": false,
        "filesystem_read": false,
        "filesystem_write": false,
        "exec": false,
        "memory_read": false,
        "memory_write": false,
        "playwright": false
      }
    }
  ],
  "skills": [
    {
      "name": "echo.basic",
      "description": "Return structured echo payloads without side effects.",
      "path": "plugins/skills/echo/basic.md",
      "targets": {
        "plugins": ["echo"],
        "resources": ["plugin:echo"],
        "actions": ["create", "read", "update", "delete"]
      },
      "tags": ["echo", "smoke-test"],
      "enabled": true
    }
  ],
  "install": {
    "summary": "No additional installation steps required.",
    "commands": []
  }
}
