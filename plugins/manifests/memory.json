{
  "api_version": "pinokio.plugin/v1",
  "id": "pinokio.memory",
  "name": "Memory System",
  "version": "1.0.0",
  "description": "Shared memory orchestration plugin backed by database router agents.",
  "requires": {
    "manifests": ["pinokio.database"],
    "plugins": ["db_router_agent", "postgres_agent"],
    "services": ["postgres_main"]
  },
  "runtime": {
    "mode": "host",
    "requires_container": false,
    "unsafe_host_access": false
  },
  "extends": {
    "agents": ["memory_agent"],
    "containers": [],
    "navigation": [],
    "settings": ["memory"],
    "pages": [],
    "resources": ["plugin:memory_agent"],
    "hooks": []
  },
  "plugins": [
    {
      "name": "memory_agent",
      "command": "node plugins/memory-agent-plugin.mjs",
      "host_only": true,
      "allowed_actions": ["create", "read", "update", "delete"],
      "managed_only": false,
      "dependencies": ["plugin:db_router_agent", "plugin:postgres_agent"],
      "capabilities": {
        "allow_spawn_child": false,
        "allow_hook_requests": false,
        "allow_network": false,
        "allow_filesystem": false
      },
      "permissions": {
        "create": true,
        "read": true,
        "update": true,
        "delete": true,
        "spawn_child": false,
        "hook_extensions": false,
        "network": false,
        "filesystem_read": false,
        "filesystem_write": false,
        "exec": false,
        "memory_read": true,
        "memory_write": true,
        "playwright": false
      }
    }
  ],
  "skills": [
    {
      "name": "memory.indexing",
      "description": "Manage retrieval and write policies for agent memory data.",
      "path": "plugins/skills/memory/indexing.md",
      "targets": {
        "plugins": ["memory_agent"],
        "resources": ["plugin:memory_agent"],
        "actions": ["create", "read", "update", "delete"]
      },
      "tags": ["memory", "indexing"],
      "enabled": true
    }
  ],
  "install": {
    "summary": "No additional installation steps required.",
    "commands": []
  }
}
