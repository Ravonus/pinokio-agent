{
  "api_version": "pinokio.plugin/v1",
  "id": "pinokio.chat",
  "name": "Chat Agents",
  "version": "1.0.0",
  "description": "Container-first chat orchestration agents and chat UI extension.",
  "runtime": {
    "mode": "container",
    "requires_container": true,
    "unsafe_host_access": false
  },
  "extends": {
    "agents": ["chat_agent", "chat_worker_agent"],
    "containers": ["chat-runtime"],
    "navigation": ["chat"],
    "settings": ["chat_agent", "chat_worker_agent"],
    "pages": ["/ui/chat"],
    "resources": ["plugin:chat_agent", "plugin:chat_worker_agent"],
    "hooks": []
  },
  "plugins": [
    {
      "name": "chat_agent",
      "command": "node plugins/chat-agent-plugin.mjs",
      "host_only": false,
      "allowed_actions": ["create", "read", "update", "delete"],
      "managed_only": false,
      "dependencies": ["plugin:chat_worker_agent"],
      "capabilities": {
        "allow_spawn_child": true,
        "allow_hook_requests": false,
        "allow_network": true,
        "allow_filesystem": false
      },
      "permissions": {
        "create": true,
        "read": true,
        "update": true,
        "delete": true,
        "spawn_child": true,
        "hook_extensions": false,
        "network": true,
        "filesystem_read": false,
        "filesystem_write": false,
        "exec": false,
        "memory_read": false,
        "memory_write": false,
        "playwright": false
      }
    },
    {
      "name": "chat_worker_agent",
      "command": "node plugins/chat-worker-agent-plugin.mjs",
      "host_only": false,
      "allowed_actions": ["create", "read", "update", "delete"],
      "managed_only": false,
      "dependencies": [],
      "capabilities": {
        "allow_spawn_child": true,
        "allow_hook_requests": false,
        "allow_network": true,
        "allow_filesystem": false
      },
      "permissions": {
        "create": true,
        "read": true,
        "update": true,
        "delete": true,
        "spawn_child": true,
        "hook_extensions": false,
        "network": true,
        "filesystem_read": false,
        "filesystem_write": false,
        "exec": true,
        "memory_read": false,
        "memory_write": false,
        "playwright": false
      }
    }
  ],
  "ui_extensions": [
    {
      "name": "chat",
      "kind": "plugins",
      "slot": "navigation",
      "title": "Chat",
      "detail": "Interactive chat UI powered by plugin:chat_agent.",
      "route": "/ui/chat",
      "order": 30,
      "enabled": true
    }
  ],
  "skills": [
    {
      "name": "chat.orchestrator",
      "description": "Coordinate chat agent delegation and safe execution paths.",
      "path": "plugins/skills/chat/orchestrator.md",
      "targets": {
        "plugins": ["chat_agent", "chat_worker_agent"],
        "resources": ["plugin:chat_agent", "plugin:chat_worker_agent"],
        "actions": ["create", "read", "update", "delete"]
      },
      "tags": ["chat", "orchestration"],
      "enabled": true
    }
  ],
  "resource_networks": {
    "plugin:chat_agent": "host",
    "plugin:chat_worker_agent": "host"
  },
  "install": {
    "summary": "No additional installation steps required.",
    "commands": []
  }
}
