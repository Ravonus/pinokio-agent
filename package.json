{
  "name": "pinokio-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "worker:check": "tsc --noEmit --strict workers/playwright-worker.ts workers/playwright-service.ts",
    "plugin:echo": "node plugins/echo/index.ts",
    "plugin:spawn-dev": "node plugins/spawn-dev-plugin.ts",
    "connection:telegram": "node plugins/telegram-connection.ts",
    "hook:connection-router": "node hooks/connection-router.ts",
    "ui:dev": "npm --prefix ui run dev",
    "ui:build": "npm --prefix ui run build",
    "ui:check": "npm --prefix ui run check",
    "test:playwright-replay": "node tests/playwright-replay.test.ts",
    "plugin:chat-agent": "node plugins/chat/index.ts",
    "plugin:postgres-agent": "node plugins/database/postgres.ts"
  },
  "dependencies": {
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "playwright-extra-plugin-stealth": "^0.0.1",
    "xstate": "^5.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "typescript": "^5.8.0"
  }
}
