{
  "name": "pinokio-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "worker:check": "node --check workers/playwright-worker.mjs && node --check workers/playwright-service.mjs",
    "plugin:echo": "node plugins/echo-plugin.mjs",
    "plugin:spawn-dev": "node plugins/spawn-dev-plugin.mjs",
